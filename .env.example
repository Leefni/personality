# Copy to .env (or configure these environment variables in your server runtime).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=personality
DB_USER=root
DB_PASS=

# Retention cleanup script (scripts/cleanup_retention.php)
RETENTION_DAYS=90
RETENTION_MAX_DELETE_PER_TABLE=5000
RETENTION_DRY_RUN=false

# Recovery links
RECOVERY_TOKEN_TTL_SECONDS=900
RECOVERY_RATE_LIMIT_WINDOW_SECONDS=3600
RECOVERY_RATE_LIMIT_MAX_PER_VISITOR=3
RECOVERY_RATE_LIMIT_MAX_PER_EMAIL=5
RECOVERY_EMAIL_FROM=no-reply@example.test
RECOVERY_BASE_URL=
